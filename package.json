{
  "name": "@ftaricano/mcp-hub",
  "version": "0.1.0",
  "description": "TypeScript MCP gateway that aggregates, searches, and routes tools from multiple Model Context Protocol servers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-hub": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "hub-config.example.json",
    "LMStudio-MCP-Config.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "postbuild": "chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check --ignore-unknown src tests testing-interface README.md SECURITY.md LMStudio-MCP-Config.md hub-config.example.json .env.example",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:performance": "vitest run --config vitest.performance.config.ts",
    "type-check": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.0",
    "dotenv": "^17.2.1",
    "node-cache": "^5.1.2",
    "p-limit": "^5.0.0",
    "p-retry": "^6.2.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hub",
    "gateway",
    "proxy",
    "tool-discovery",
    "tool-routing",
    "aggregation",
    "server-registry",
    "ai-tools",
    "llm-tools",
    "developer-tools"
  ],
  "author": "Fernando Taricano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ftaricano/mcp-hub.git"
  },
  "bugs": {
    "url": "https://github.com/ftaricano/mcp-hub/issues"
  },
  "homepage": "https://github.com/ftaricano/mcp-hub#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@10"
}
