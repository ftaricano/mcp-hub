# MCP Hub - Secure Environment Configuration
# Copy this file to .env and fill in only the credentials needed by the MCP servers you actually register.
# The sections below are optional service examples, not built-in hub dependencies.

# ==============================================
# REQUIRED: Microsoft Graph Services
# ==============================================
# Used by: email-advanced, onedrive-sharepoint servers
# Get these from: https://portal.azure.com > App registrations
MICROSOFT_GRAPH_CLIENT_ID=your_client_id_here
MICROSOFT_GRAPH_CLIENT_SECRET=your_client_secret_here
MICROSOFT_GRAPH_TENANT_ID=your_tenant_id_here

# Optional: Specify target user email for multi-tenant scenarios
TARGET_USER_EMAIL=fernando.taricano@cpzseg.com.br

# ==============================================
# REQUIRED: Trello Integration
# ==============================================
# Get these from: https://trello.com/app-key
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here

# Optional: Default board ID
TRELLO_BOARD_ID=your_default_board_id

# ==============================================
# REQUIRED: Spotify Integration
# ==============================================
# Get these from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback
CALLBACK_PORT=3000

# ==============================================
# REQUIRED: YouTube Integration
# ==============================================
# Get these from: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8080/callback
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly,https://www.googleapis.com/auth/youtube.upload,https://www.googleapis.com/auth/youtube,https://www.googleapis.com/auth/youtubepartner,https://www.googleapis.com/auth/yt-analytics.readonly

# ==============================================
# REQUIRED: GitHub Integration
# ==============================================
# Get this from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# Optional: GitHub App credentials (alternative to personal token)
# GITHUB_APP_ID=your_github_app_id
# GITHUB_PRIVATE_KEY=your_github_app_private_key

# ==============================================
# REQUIRED: Notion Integration
# ==============================================
# Get this from: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# ==============================================
# OPTIONAL: WhatsApp Business Integration
# ==============================================
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v17.0

# ==============================================
# SECURITY CONFIGURATION
# ==============================================
# Environment (development, staging, production)
NODE_ENV=development

# Encryption key for credential storage (generate with: openssl rand -hex 32)
# MCP_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# ==============================================
# PERFORMANCE CONFIGURATION
# ==============================================
# Node.js memory allocation
NODE_OPTIONS=--max-old-space-size=2048

# ==============================================
# OPTIONAL: Advanced Configuration
# ==============================================
# Logging
LOG_LEVEL=info
DEBUG=false

# Cache settings
CACHE_ENABLED=true
CACHE_DURATION=3600
TOKEN_CACHE_TTL=86400

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
YOUTUBE_RATE_LIMIT=50

# Timeouts (milliseconds)
API_TIMEOUT=60000
GITHUB_TIMEOUT=30000

# Batch processing
BATCH_SIZE=20

# Token storage paths
TOKEN_STORAGE_PATH=/absolute/path/to/tokens.json
SPOTIFY_TOKEN_PATH=/absolute/path/to/spotify-tokens.json

# ==============================================
# DEVELOPMENT CONFIGURATION
# ==============================================
# For testing and development
FORCE_TOKEN_REFRESH=false
AUTO_REFRESH_TOKENS=true
YOUTUBE_QUOTA_MANAGEMENT=true
VALIDATE_SCHEMAS=true

# Temp directories
WHATSAPP_TEMP_DIR=./temp
TEMP_DIR=/tmp/mcp-hub

# ==============================================
# INSTRUCTIONS
# ==============================================
# 1. Copy this file to .env in the same directory
# 2. Fill in your actual credentials (never commit the .env file)
# 3. Make sure .env is in your .gitignore
# 4. For production, consider using a key vault service
# 5. Restart the MCP Hub after updating credentials

# Security Notes:
# - Never commit credentials to version control
# - Use environment-specific credentials
# - Rotate credentials regularly
# - Use HTTPS for redirect URIs in production
# - Enable encryption for production environments