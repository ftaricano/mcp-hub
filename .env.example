# MCP Hub example environment
# Copy to .env only for local development. Never commit a filled .env file.

# Hub runtime
NODE_ENV=development
LOG_LEVEL=info
DEBUG=false
HUB_CONFIG=./hub-config.json

# Optional per-server environment files.
# Prefer envFile in hub-config.json when each downstream server has its own .env.
MCP_DOCS_SERVER_ENV_PATH=/absolute/path/to/docs-server/.env
MCP_ISSUE_TRACKER_ENV_PATH=/absolute/path/to/issue-tracker/.env

# Optional service examples for downstream MCP servers you register yourself.
# MCP Hub does not require these variables unless your configured downstream server does.
MICROSOFT_GRAPH_CLIENT_ID=your_client_id_here
MICROSOFT_GRAPH_CLIENT_SECRET=your_client_secret_here
MICROSOFT_GRAPH_TENANT_ID=your_tenant_id_here
TARGET_USER_EMAIL=user@example.com

GITHUB_TOKEN=your_github_token_here
NOTION_TOKEN=your_notion_token_here
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:8080/callback
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly

WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Runtime tuning
CACHE_ENABLED=true
CACHE_DURATION=3600
RATE_LIMIT_PER_MINUTE=60
API_TIMEOUT=60000
BATCH_SIZE=20

# Local token/cache paths. Keep these outside the repository when possible.
TOKEN_STORAGE_PATH=/absolute/path/to/local/tokens.json
TEMP_DIR=/tmp/mcp-hub

# Security checklist:
# - Store real secrets in .env, a key vault, or your downstream server's own config.
# - Keep .env, token files, auth state, private keys, logs, and generated traces out of Git.
# - Rotate any credential immediately if it is committed or pasted into an issue/PR.
