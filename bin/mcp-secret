#!/usr/bin/env node

/**
 * MCP Secret Manager CLI Entry Point
 * 100% Free Local Secret Management
 */

import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

// Get the directory of this script
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Import and run the CLI
async function main() {
  try {
    // Import the CLI module
    const { SecretCLI } = await import(join(__dirname, '../dist/secrets/cli/secret-cli.js'));
    
    // Create and run CLI
    const cli = new SecretCLI();
    const args = process.argv.slice(2);
    
    await cli.run(args);
  } catch (error) {
    if (error.code === 'MODULE_NOT_FOUND') {
      console.error('❌ MCP Secret Manager not built yet.');
      console.error('📝 Run: cd mcp-hub && npm run build');
      process.exit(1);
    } else {
      console.error('❌ Error:', error.message);
      process.exit(1);
    }
  }
}

main().catch(console.error);